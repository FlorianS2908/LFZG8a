{
    "name":  "uetool-assass",
    "version":  "0.1.0",
    "description":  "ueTool_asSaaS Desktop-App fuer ContentFactory, DokuTool, QuizTools und HTML/CSS-Unterrichtsumgebung.",
    "main":  "app/main.js",
    "private":  true,
    "author":  "Ploglan",
    "productName":  "ueTool_asSaaS",
    "scripts":  {
                    "start":  "electron .",
                    "dev":  "electron .",
                    "check":  "node scripts/check-all.js",
                    "test":  "node tests/run-tests.js",
                    "test:electron":  "electron tests/electron-course-smoke.js \u0026\u0026 electron tests/electron-workspace-smoke.js",
                    "test:watch":  "node tests/run-tests.js",
                    "verify":  "node scripts/check-all.js \u0026\u0026 node tests/run-tests.js",
                    "dist":  "electron-builder --win"
                },
    "build":  {
                  "appId":  "de.ploglan.toolzentrale",
                  "productName":  "ueTool_asSaaS",
                  "directories":  {
                                      "output":  "dist"
                                  },
                  "files":  [
                                "app/**/*",
                                "package.json"
                            ],
                  "win":  {
                              "icon":  "app/assets/icons/app-icon.ico",
                              "signAndEditExecutable":  false,
                              "target":  [
                                             "nsis"
                                         ]
                          },
                  "nsis":  {
                               "oneClick":  false,
                               "perMachine":  false,
                               "allowToChangeInstallationDirectory":  true,
                               "createDesktopShortcut":  true,
                               "createStartMenuShortcut":  true,
                               "shortcutName":  "ueTool_asSaaS"
                           }
              },
    "devDependencies":  {
                            "electron":  "^31.7.7",
                            "electron-builder":  "^24.13.3"
                        }
}
