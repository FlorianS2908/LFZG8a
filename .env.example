# OPENAI_API_KEY niemals in Git committen.
# Key manuell in der OpenAI Platform erzeugen.
# Lokal entweder in .env eintragen oder als System-Umgebungsvariable setzen.
AI_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_PROMPT_CHARS=40000
CONTENT_FACTORY_AI_REVIEW=false
CONTENT_FACTORY_COST_WARNING_USD=1.00
