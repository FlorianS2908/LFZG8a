# OPENAI_API_KEY niemals in Git committen.
# Key manuell in der OpenAI Platform erzeugen.
# Key bevorzugt über die KI-Einstellungen in Electrons safeStorage übernehmen.
# OPENAI_API_KEY ist nur eine bewusste Entwicklungsalternative.
# Ohne Key läuft CourseForge im Local/Fallback-Modus.
# Die historische Datei api_key_ContentFactory.txt ist ausschließlich eine Import-Kompatibilität und darf niemals ins Repository.
AI_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=2
OPENAI_MAX_PROMPT_CHARS=40000
COURSEFORGE_AI_REVIEW=false
COURSEFORGE_COST_WARNING_USD=1.00
